# Copy to .env.local — never commit real secrets

# App
NEXT_PUBLIC_APP_URL=https://www.dyluxepro.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=DyluxePro <noreply@dyluxepro.com>
RESEND_VERIFIED_EMAIL=
CONTACT_EMAIL=support@dyluxepro.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_ID_PROFESSIONAL=
NEXT_PUBLIC_STRIPE_PRICE_ID_ENTERPRISE=

# Rate limiting (Upstash) — required in production
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Security
CRON_SECRET=
ESTIMATE_ACTION_SECRET=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# AI estimates (optional)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_PRICING_MODEL=gpt-4o-mini

# Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
